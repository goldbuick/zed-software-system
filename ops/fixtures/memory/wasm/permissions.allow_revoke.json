{
  "name": "permissions.allow_revoke",
  "initial": {},
  "steps": [
    {
      "op": "permission_reset",
      "expect": {
        "mode": "json",
        "json": true
      }
    },
    {
      "op": "permission_apply_config",
      "args": {
        "config": "creative"
      },
      "expect": {
        "mode": "json",
        "json": true
      }
    },
    {
      "op": "permission_allow_command",
      "args": {
        "role": "player",
        "command": "roles"
      },
      "expect": {
        "mode": "json",
        "json": true
      }
    },
    {
      "op": "permission_role_has_family",
      "args": {
        "role": "player",
        "family": "roles"
      },
      "expect": {
        "mode": "json",
        "json": true
      }
    },
    {
      "op": "permission_revoke_command",
      "args": {
        "role": "player",
        "command": "build"
      },
      "expect": {
        "mode": "json",
        "json": true
      }
    },
    {
      "op": "permission_role_has_family",
      "args": {
        "role": "player",
        "family": "build"
      },
      "expect": {
        "mode": "json",
        "json": false
      }
    }
  ]
}
