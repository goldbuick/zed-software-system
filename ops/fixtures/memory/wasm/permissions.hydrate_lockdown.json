{
  "name": "permissions.hydrate_lockdown",
  "initial": {},
  "steps": [
    {
      "op": "permission_reset",
      "expect": {
        "mode": "json",
        "json": true
      }
    },
    {
      "op": "permission_set_command_permissions",
      "args": {
        "bannedtokens": [],
        "rolebytoken": {},
        "permissionconfig": "lockdown",
