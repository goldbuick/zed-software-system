          "mod": [
            "bridge",
            "coder",
            "explore",
            "moderation",
            "persist",
            "speaker"
          ],
          "player": []
        }
      }
    },
    {
      "op": "permission_role_has_family",
      "args": {
        "role": "mod",
        "family": "persist"
      },
      "expect": {
        "mode": "json",
        "json": true
      }
    }
