    "deploy:gcp-cloudrun:run": "sh scripts/gcp-deploy-cloudrun.sh",
    "deploy:gcp-vm:create": "sh scripts/gcp-vm-create.sh",
    "deploy:gcp-vm:docker-run": "sh scripts/gcp-vm-docker-run.sh",
    "deploy:gcp-vm:firewall": "sh scripts/gcp-vm-firewall.sh",
    "deploy:gcp:artifact-repo": "sh scripts/gcp-artifact-repo.sh",
    "deploy:gcp:enable-apis": "sh scripts/gcp-enable-apis.sh",
    "deploy:gcp:push": "sh scripts/gcp-push.sh",
    "deploy:vm:docker-run": "sh scripts/vm-zss-docker-run.sh",
    "docs:check-links": "node scripts/check-doc-links.mjs",
