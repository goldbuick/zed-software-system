{
  "name": "zed-software-system",
  "private": true,
  "version": "1.8.5",
  "type": "module",
  "files": [
    "bin",
    "cafe/dist",
    "dist",
    "src/fixtures/example-coolregionsbow.book.json"
  ],
  "scripts": {
    "adsr-parity:test": "yarn jest zss/feature/synth/backend/wasm/__tests__/adsrenvcurve.test.ts && yarn env-parity:test",
    "app:analyze": "NODE_OPTIONS=--max-old-space-size=8192 ZSS_ANALYZER=1 yarn app:build",
    "app:audit:deadcode": "knip --include files,exports,dependencies --no-exit-code",
    "app:audit:export-catalogs": "node scripts/audit-export-catalogs.mjs",
    "app:build": "vite build",
    "app:build:strict": "tsc && vite build",
    "app:clear": "rimraf tmp && rimraf dist && rimraf cafe/dist && rimraf node_modules/.vite",
    "app:dev": "yarn && yarn vite:dev",
    "app:dev:no-sc": "ZSS_DAISY_NO_SIDECHAIN=1 yarn app:dev",
    "app:tslang:dev": "yarn && ZSS_WASM_SCRIPT=false yarn vite:dev",
    "app:wasm:dev": "yarn lang:build && yarn app:dev",
    "app:lint": "depcruise zss/simspace.ts zss/heavyspace.ts zss/boardrunnerspace.ts zss/sttspace.ts --validate --config .dependency-cruiser.cjs && eslint . --ext ts,tsx --fix --report-unused-disable-directives --max-warnings 0 && tsc --noEmit",
    "app:preview": "vite preview --host 0.0.0.0 --port 7777",
    "app:sloc": "npx sloc -e .js -e '__tests__|\\.test\\.(ts|tsx)$' zss",
    "app:test": "yarn jest --verbose",
    "app:test:coverage": "yarn jest --coverage --collectCoverageFrom='zss/device/vm/gadgetsynctick.ts' --collectCoverageFrom='zss/device/vm/handlers/scroll.ts' --collectCoverageFrom='zss/device/vm/handlers/ticktock.ts' --collectCoverageFrom='zss/device/boardrunner/handlers/linkdead.ts' --collectCoverageFrom='zss/device/gadgetclient.ts'",
    "ci:pages:copy-404": "cp .github/404.html ./cafe/dist",
    "ci:pages:copy-cname": "cp .github/CNAME ./cafe/dist",
    "content:book:build": "node scripts/content-cli.mjs build",
    "content:book:validate": "node scripts/content-cli.mjs validate",
    "content:book:test": "yarn jest zss/feature/content/__tests__/contentbook.test.ts --no-coverage",
    "content:codepage:validate": "node scripts/content-cli.mjs codepage-validate",
    "cli:build": "tsc -p tsconfig.cli.json && oclif manifest",
    "cli:build:all": "NODE_ENV=production yarn app:build && NODE_ENV=production yarn cli:build && oclif pack tarballs",
    "cli:build:linux": "NODE_ENV=production yarn app:build && NODE_ENV=production yarn cli:build && oclif pack tarballs -t linux-x64",
    "daisy-regression:test": "npx tsx scripts/run-daisy-regression.ts",
    "daisy:bench:synth": "ZSS_DAISY_BENCH=1 npx tsx zss/feature/synth/backend/daisy/daisyperfbench.ts",
    "daisy:build": "sh zss/feature/synth/backend/daisy/native/build-daisy.sh",
    "daisy:bundle:processor": "tsx scripts/bundle-daisy-processor.ts",
    "daisy:lint": "sh scripts/clang-format.sh check daisy",
    "daisy:lint:fix": "sh scripts/clang-format.sh fix daisy",
    "deploy:aws-ec2:docker-run": "sh scripts/aws-ec2-docker-run.sh",
    "deploy:cloudflare:brick": "wrangler deploy -c infra/wrangler-brick.toml",
    "deploy:cloudflare:bytes": "wrangler deploy -c infra/wrangler-bytes.toml",
    "deploy:cloudflare:terminal": "wrangler deploy -c infra/wrangler-terminal.toml",
    "deploy:cloudflare:zns": "wrangler deploy -c infra/wrangler-zns.toml",
