{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "cafe/index.tsx",
    "cafe/sys/index.tsx",
    "zss/simspace.ts",
    "zss/heavyspace.ts",
    "zss/boardrunnerspace.ts",
    "cafecli/src/commands/run.ts",
    "jest.config.ts",
    "playwright.config.ts"
  ],
  "project": [
    "zss/**/*.{ts,tsx}",
    "cafe/**/*.{ts,tsx}",
    "cafecli/src/**/*.{ts,tsx}"
  ],
  "ignoreExportsUsedInFile": true,
  "ignore": [
    "zss/feature/synth/archive/**",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "zss/rom/**"
  ],
  "ignoreDependencies": ["@types/*"]
}
