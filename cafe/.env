# quick debug fiddles
# make your own .env.local to override these values
# Hostname for dev server HTTPS cert (e.g. machine name so https://myhost:7777 works in Firefox)
# ZSS_DEV_HOST=little-funk
# If modules fail with empty MIME: run `yarn clear`, restart dev, or set ZSS_NO_HTTPS=true and open http://localhost:7777

// vite config
ZSS_HMR_ONLY=false
ZSS_ANALYZER=false

// debug config
ZSS_DEBUG_LOG=false
ZSS_DEBUG_LANG_DEV=false
ZSS_DEBUG_LANG_TYPES=false
ZSS_DEBUG_PERF_UI=false
ZSS_DEBUG_SHOW_CODE=false
ZSS_DEBUG_TRACE_CODE=false
ZSS_DEBUG_RAYCAST_DOT=false
ZSS_DEBUG_RAYCAST_PICKSHEET=false

// engine config
ZSS_FORCE_CRT_OFF=false
ZSS_FORCE_LOW_REZ=false
ZSS_FORCE_TOUCH_UI=false
