{
  "name": "permissions.canrun_allowlisted",
  "initial": {},
  "steps": [
    {
      "op": "permission_reset",
      "expect": {
        "mode": "json",
        "json": true
      }
    },
    {
      "op": "permission_set_player_token",
      "args": {
        "player": "player1",
        "token": "token-a"
      },
      "expect": {
        "mode": "json",
        "json": true
      }
    },
    {
      "op": "permission_set_role_for_token",
      "args": {
        "token": "token-a",
        "role": "player"
      },
      "expect": {
        "mode": "json",
        "json": true
      }
    },
    {
      "op": "permission_can_run",
      "args": {
        "player": "player1",
        "command": "toast"
      },
      "expect": {
        "mode": "json",
        "json": {
          "allowed": true,
          "deny_reason": ""
        }
      }
    }
  ]
}
